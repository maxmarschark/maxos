# Supabase (optional — app falls back to localStorage when unset)
# Project URL → VITE_SUPABASE_URL
# Publishable Key (anon) → VITE_SUPABASE_ANON_KEY
#
# When Supabase is configured, Google Sign-In is required (enable Google provider
# in Supabase Dashboard → Authentication → Providers).
#
# Supabase Dashboard → Authentication → URL Configuration → Redirect URLs:
#   http://localhost:5180
#   http://localhost:5180/#/settings
#   https://maxos-ashen.vercel.app
#   https://maxos-ashen.vercel.app/#/settings
VITE_SUPABASE_URL=
VITE_SUPABASE_ANON_KEY=
